apiVersion: v1
kind: Secret
metadata:
  name: linkding-env
  namespace: {{ app.namespace }}
type: Opaque
stringData:
  LD_DB_ENGINE: "postgres"
  LD_DB_DATABASE: "{{ postgres_lxc_db }}"
  LD_DB_USER: "{{ postgres_lxc_user }}"
  LD_DB_PASSWORD: "{{ vault_postgres_app_password }}"
  LD_DB_HOST: "{{ postgres_lxc_host }}"
  LD_DB_PORT: "{{ postgres_lxc_port }}"
  LD_SECRET_KEY: "{{ vault_linkding_secret_key }}"
  LD_SUPERUSER_NAME: "{{ vault_linkding_superuser_name }}"
  LD_SUPERUSER_PASSWORD: "{{ vault_linkding_superuser_password }}"
