apiVersion: gateway.networking.k8s.io/v1
kind: Gateway
metadata:
  name: {{ gateway_name }}
  namespace: {{ namespace_gateway }}
spec:
  gatewayClassName: {{ gateway_class_name }}
  listeners:
  - name: http
    protocol: HTTP
    port: 80
    allowedRoutes:
      namespaces:
        from: All
  - name: https
    protocol: HTTPS
    port: 443
    hostname: "*.{{ homelab_domain }}"
    tls:
      mode: Terminate
      certificateRefs:
      - name: {{ wildcard_tls_secret_name }}
    allowedRoutes:
      namespaces:
        from: All
