apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: pgadmin
  namespace: {{ namespace_postgres }}
spec:
  parentRefs:
    - name: "{{ gateway_name }}"
      namespace: "{{ namespace_gateway }}"
  hostnames:
    - "{{ pgadmin_domain }}"
  rules:
    - backendRefs:
        - name: pgadmin
          port: 80
