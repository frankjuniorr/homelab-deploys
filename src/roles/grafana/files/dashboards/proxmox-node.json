{
  "annotations": { "list": [] },
  "description": "Proxmox host metrics (node_exporter) + per-VM/LXC metrics (textfile collector)",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Host — Proxmox Node",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "percentage", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }, "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"proxmox-node\",mode=\"idle\"}[$__rate_interval])) * 100)",
        "legendFormat": "CPU", "refId": "A"
      }],
      "title": "CPU Usage",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "percentage", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }, "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "(1 - node_memory_MemAvailable_bytes{job=\"proxmox-node\"} / node_memory_MemTotal_bytes{job=\"proxmox-node\"}) * 100",
        "legendFormat": "RAM", "refId": "A"
      }],
      "title": "RAM Usage",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "percentage", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 70 },
            { "color": "red", "value": 90 }
          ]},
          "unit": "percent", "min": 0, "max": 100
        }, "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "(node_filesystem_size_bytes{job=\"proxmox-node\",mountpoint=\"/\",fstype!=\"tmpfs\"} - node_filesystem_free_bytes{job=\"proxmox-node\",mountpoint=\"/\",fstype!=\"tmpfs\"}) / node_filesystem_size_bytes{job=\"proxmox-node\",mountpoint=\"/\",fstype!=\"tmpfs\"} * 100",
        "legendFormat": "Disk /", "refId": "A"
      }],
      "title": "Disk Usage /",
      "type": "gauge"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "node_load1{job=\"proxmox-node\"}",
        "legendFormat": "Load 1m", "refId": "A"
      }],
      "title": "Load Average 1m",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "green", "mode": "fixed" }, "unit": "dtdurations" },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "node_time_seconds{job=\"proxmox-node\"} - node_boot_time_seconds{job=\"proxmox-node\"}",
        "legendFormat": "Uptime", "refId": "A"
      }],
      "title": "Uptime",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 4 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "node_load5{job=\"proxmox-node\"}",
        "legendFormat": "Load 5m", "refId": "A"
      }],
      "title": "Load Average 5m",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 4 },
      "id": 7,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "node_load15{job=\"proxmox-node\"}",
        "legendFormat": "Load 15m", "refId": "A"
      }],
      "title": "Load Average 15m",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 8,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "avg(rate(node_cpu_seconds_total{job=\"proxmox-node\",mode!=\"idle\"}[$__rate_interval]))",
        "legendFormat": "CPU", "refId": "A"
      }],
      "title": "CPU Usage over time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 9,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_memory_MemTotal_bytes{job=\"proxmox-node\"} - node_memory_MemAvailable_bytes{job=\"proxmox-node\"}",
          "legendFormat": "Used", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "node_memory_MemTotal_bytes{job=\"proxmox-node\"}",
          "legendFormat": "Total", "refId": "B"
        }
      ],
      "title": "RAM Usage over time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(node_network_transmit_bytes_total{job=\"proxmox-node\",device!=\"lo\"}[$__rate_interval])",
          "legendFormat": "TX {{device}}", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(node_network_receive_bytes_total{job=\"proxmox-node\",device!=\"lo\"}[$__rate_interval])",
          "legendFormat": "RX {{device}}", "refId": "B"
        }
      ],
      "title": "Network TX / RX",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 101,
      "title": "VMs & LXC Containers",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "mappings", "value": [
                { "options": { "1": { "color": "green", "index": 0, "text": "running" } }, "type": "value" },
                { "options": { "0": { "color": "red",   "index": 1, "text": "stopped" } }, "type": "value" }
              ]}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CPU %" },
            "properties": [{ "id": "unit", "value": "percentunit" }]
          },
          {
            "matcher": { "id": "byName", "options": "RAM Used" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "RAM Total" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 11,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": false, "displayName": "Name" }] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "proxmox_guest_status{job=\"proxmox-node\",name=~\"$guest\"}",
          "format": "table", "instant": true, "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "proxmox_guest_cpu_usage{job=\"proxmox-node\",name=~\"$guest\"}",
          "format": "table", "instant": true, "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "proxmox_guest_memory_used_bytes{job=\"proxmox-node\",name=~\"$guest\"}",
          "format": "table", "instant": true, "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "proxmox_guest_memory_max_bytes{job=\"proxmox-node\",name=~\"$guest\"}",
          "format": "table", "instant": true, "refId": "D"
        }
      ],
      "title": "Guest Overview",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "filterFieldsByName", "options": { "include": { "names": ["name", "type", "vmid", "Value #A", "Value #B", "Value #C", "Value #D"] } } },
        { "id": "organize", "options": { "renameByName": {
          "name": "Name", "type": "Type", "vmid": "VMID",
          "Value #A": "Status", "Value #B": "CPU %",
          "Value #C": "RAM Used", "Value #D": "RAM Total"
        }}}
      ],
      "type": "table"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "id": 12,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "proxmox_guest_cpu_usage{job=\"proxmox-node\",name=~\"$guest\"}",
        "legendFormat": "{{name}} ({{type}})", "refId": "A"
      }],
      "title": "CPU Usage per Guest",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "id": 13,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "proxmox_guest_memory_used_bytes{job=\"proxmox-node\",name=~\"$guest\"} / proxmox_guest_memory_max_bytes{job=\"proxmox-node\",name=~\"$guest\"} > 0",
        "legendFormat": "{{name}} ({{type}})", "refId": "A"
      }],
      "title": "RAM Usage % per Guest",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "id": 14,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(proxmox_guest_netout_bytes_total{job=\"proxmox-node\",name=~\"$guest\"}[$__rate_interval])",
        "legendFormat": "{{name}} TX", "refId": "A"
      }],
      "title": "Network TX per Guest",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "id": 15,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "rate(proxmox_guest_netin_bytes_total{job=\"proxmox-node\",name=~\"$guest\"}[$__rate_interval])",
        "legendFormat": "{{name}} RX", "refId": "A"
      }],
      "title": "Network RX per Guest",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 56 },
      "id": 16,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(proxmox_guest_disk_read_bytes_total{job=\"proxmox-node\",name=~\"$guest\"}[$__rate_interval])",
          "legendFormat": "{{name}} read", "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(proxmox_guest_disk_write_bytes_total{job=\"proxmox-node\",name=~\"$guest\"}[$__rate_interval])",
          "legendFormat": "{{name}} write", "refId": "B"
        }
      ],
      "title": "Disk I/O per Guest",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["proxmox", "node-exporter", "homelab"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(proxmox_guest_status{job=\"proxmox-node\"}, name)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Guest",
        "multi": true,
        "name": "guest",
        "options": [],
        "query": {
          "query": "label_values(proxmox_guest_status{job=\"proxmox-node\"}, name)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Proxmox Node",
  "uid": "homelab-proxmox-node",
  "version": 1
}
