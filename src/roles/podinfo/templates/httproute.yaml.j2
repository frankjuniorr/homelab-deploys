apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: {{ app.name }}-route
  namespace: {{ app.namespace }}
spec:
  parentRefs:
  - name: {{ gateway_name }}
    namespace: {{ namespace_gateway }}
  hostnames:
  - "{{ app.domain }}"
  rules:
  - matches:
    - path: { type: PathPrefix, value: / }
    backendRefs:
    - name: {{ app.name }}-svc
      port: 80
