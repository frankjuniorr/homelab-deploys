apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: longhorn-route
  namespace: {{ longhorn_namespace }}
spec:
  parentRefs:
  - name: {{ gateway_name }}
    namespace: {{ namespace_gateway }}
  hostnames:
  - "{{ longhorn_domain }}"
  rules:
  - matches:
    - path: { type: PathPrefix, value: / }
    backendRefs:
    - name: longhorn-frontend
      port: 80
