deploymentMode: SingleBinary

loki:
  auth_enabled: false
  commonConfig:
    replication_factor: 1
  storage:
    type: filesystem
  schemaConfig:
    configs:
      - from: "2024-01-01"
        store: tsdb
        object_store: filesystem
        schema: v13
        index:
          prefix: loki_index_
          period: 24h
  limits_config:
    retention_period: "{{ loki_retention }}"
  compactor:
    retention_enabled: true
    delete_request_store: filesystem

singleBinary:
  replicas: 1
  persistence:
    enabled: true
    storageClass: longhorn-single
    size: "{{ loki_storage_size }}"
  resources:
    requests:
      cpu: "{{ loki_req_cpu }}"
      memory: "{{ loki_req_mem }}"
    limits:
      cpu: "{{ loki_lim_cpu }}"
      memory: "{{ loki_lim_mem }}"

read:
  replicas: 0

write:
  replicas: 0

backend:
  replicas: 0

# Disable Memcached cache sidecars — not needed for single binary homelab mode
chunksCache:
  enabled: false

resultsCache:
  enabled: false

# Disable canary and helm test — unnecessary in homelab (saves 3×12Mi)
lokiCanary:
  enabled: false

test:
  enabled: false
