grafana:
  enabled: false   # Grafana is deployed as a standalone release in the 'grafana' namespace
  forceDeployDashboards: true   # still create dashboard ConfigMaps in the 'prometheus' namespace
  defaultDashboardsAnnotations:
    grafana_folder: Kubernetes   # sidecar uses this annotation to place them in a folder

prometheus:
  prometheusSpec:
    scrapeInterval: "{{ prometheus_scrape_interval }}"
    evaluationInterval: "{{ prometheus_eval_interval }}"
    retention: "{{ prometheus_retention }}"
    storageSpec:
      volumeClaimTemplate:
        spec:
          storageClassName: longhorn
          accessModes: ["ReadWriteOnce"]
          resources:
            requests:
              storage: "{{ prometheus_storage_size }}"
    additionalScrapeConfigs:
      - job_name: proxmox-node
        static_configs:
          - targets:
              - "{{ proxmox_host_ip }}:9100"
            labels:
              node: proxmox
    resources:
      requests:
        cpu: "{{ prometheus_req_cpu }}"
        memory: "{{ prometheus_req_mem }}"
      limits:
        cpu: "{{ prometheus_lim_cpu }}"
        memory: "{{ prometheus_lim_mem }}"

alertmanager:
  alertmanagerSpec:
    resources:
      requests:
        cpu: "{{ alertmanager_req_cpu }}"
        memory: "{{ alertmanager_req_mem }}"
      limits:
        cpu: "{{ alertmanager_lim_cpu }}"
        memory: "{{ alertmanager_lim_mem }}"
