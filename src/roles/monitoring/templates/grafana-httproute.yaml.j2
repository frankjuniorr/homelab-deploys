apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: grafana-route
  namespace: {{ namespace_grafana }}
spec:
  parentRefs:
  - name: {{ gateway_name }}
    namespace: {{ namespace_gateway }}
  hostnames:
  - "{{ monitoring_grafana_domain }}"
  rules:
  - matches:
    - path: { type: PathPrefix, value: / }
    backendRefs:
    - name: grafana
      port: 80
